{
  "name": "pdf-merger",
  "version": "1.0.3",
  "author": "Massimo Lanera",
  "description": "Unisci più PDF in un unico file",
  "main": "electron/main.js",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "electron:dev": "concurrently \"ng serve\" \"wait-on http://localhost:4200 && electron .\"",
    "preelectron:build": "npm version patch --no-git-tag-version",
    "electron:build": "ng build --configuration production && electron-builder build --win --x64",
    "test": "ng test",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "deploy": "ng deploy --base-href=/pdf-merged/"
  },
  "build": {
    "appId": "com.pdfmerger.app",
    "productName": "PDF Merger",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "src/assets/logo-ico.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "src/assets/logo-ico.ico",
      "uninstallerIcon": "src/assets/logo-ico.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "~21.2.9",
    "@angular/common": "~21.2.9",
    "@angular/compiler": "~21.2.9",
    "@angular/core": "~21.2.9",
    "@angular/forms": "~21.2.9",
    "@angular/platform-browser": "~21.2.9",
    "@angular/platform-browser-dynamic": "~21.2.9",
    "@angular/router": "~21.2.9",
    "jszip": "^3.10.1",
    "pdf-lib": "^1.17.1",
    "rxjs": "~7.8.2",
    "tslib": "^2.0.0",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "~21.2.7",
    "@angular/cli": "~21.2.7",
    "@angular/compiler-cli": "~21.2.9",
    "@eslint/js": "^9.39.4",
    "@types/jasmine": "~3.6.0",
    "@types/node": "^12.11.1",
    "angular-cli-ghpages": "^3.1.0",
    "angular-eslint": "^21.3.1",
    "codelyzer": "^6.0.0",
    "concurrently": "^9.2.1",
    "electron": "^30.5.1",
    "electron-builder": "^22.14.13",
    "eslint": "^9.39.4",
    "jasmine-core": "~3.6.0",
    "jasmine-spec-reporter": "~5.0.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage": "~2.0.3",
    "karma-jasmine": "~4.0.0",
    "karma-jasmine-html-reporter": "^1.5.0",
    "protractor": "~7.0.0",
    "ts-node": "~8.3.0",
    "tslint": "~6.1.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.58.2",
    "wait-on": "^9.0.5"
  }
}
